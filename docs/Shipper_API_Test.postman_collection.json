		{
			"name": "❌ 4. S-64: Delivery Failure Report",
			"description": "Report delivery failure with reason.\n\nFlow:\n1. GET failure-report → load delivery info\n2. POST failure-report → submit failure reason\n\nAfter submit:\n- delivery.status → FAILED\n- transaction.status → IN_DISPUTE\n- Notification sent to buyer & seller",
			"item": [
				{
					"name": "S-64.A: Load Failure Report Screen",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test('Has delivery info for failure report', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('deliveryId');",
									"    pm.expect(jsonData).to.have.property('transactionId');",
									"    pm.expect(jsonData).to.have.property('listingId');",
									"    pm.expect(jsonData).to.have.property('buyerName');",
									"    pm.expect(jsonData).to.have.property('buyerPhone');",
									"    pm.expect(jsonData).to.have.property('sellerName');",
									"    pm.expect(jsonData).to.have.property('deliveryAddress');",
									"    pm.expect(jsonData).to.have.property('productName');",
									"    pm.expect(jsonData).to.have.property('deliveryStatus');",
									"    pm.expect(jsonData).to.have.property('transactionStatus');",
									"    pm.expect(jsonData.deliveryStatus).to.equal('IN_PROGRESS');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{shipperToken}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/api/shipper/deliveries/{{deliveryId}}/failure-report",
							"host": ["{{baseUrl}}"],
							"path": ["api", "shipper", "deliveries", "{{deliveryId}}", "failure-report"]
						}
					}
				},
				{
					"name": "S-64.B: Submit Failure Report",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 200', function () {",
