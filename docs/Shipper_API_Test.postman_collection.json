									"});",
									"pm.test('Failure report submitted', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.message).to.equal('Delivery failed report submitted successfully');",
									"    pm.expect(jsonData.deliveryId).to.be.a('number');",
									"    pm.expect(jsonData.deliveryStatus).to.equal('FAILED');",
									"    pm.expect(jsonData.transactionStatus).to.equal('IN_DISPUTE');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{shipperToken}}" }
						],
