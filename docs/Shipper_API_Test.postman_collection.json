			"name": "🔑 0. Login Shipper",
			"description": "Login as shipper to get JWT token",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"if (jsonData.token) {",
							"    pm.collectionVariables.set('shipperToken', jsonData.token);",
							"    console.log('Shipper token saved');",
							"}",
							"pm.test('Login successful', function () {",
							"    pm.response.to.have.status(200);",
							"    pm.expect(jsonData.token).to.not.be.empty;",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Content-Type", "value": "application/json" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"shipper@test.com\",\n    \"password\": \"123456\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/auth/login",
					"host": ["{{baseUrl}}"],
					"path": ["api", "auth", "login"]
				}
			}
		},
