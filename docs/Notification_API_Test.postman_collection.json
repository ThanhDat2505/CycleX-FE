{
	"info": {
		"_postman_id": "cyclex-notification-api-test-2026",
		"name": "CycleX - Notification API Test",
		"description": "API test collection for Notification module.\n\nCovers:\n- Get notification list (pagination + filters)\n- Get unread count\n- Get notification detail\n- Mark single notification as read\n- Mark all notifications as read\n- Error cases (401, 404)\n\nNotification types: DELIVERY_SUCCESS, DELIVERY_FAILED, PURCHASE_REQUEST, SELLER_CONFIRMED, BUYER_CONFIRMED, INSPECTION_COMPLETE, SYSTEM\n\nBase URL: http://localhost:4491",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:4491",
			"type": "string"
		},
		{
			"key": "userToken",
			"value": "",
			"type": "string"
		},
		{
			"key": "notificationId",
			"value": "1",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "🔑 0. Login User",
			"description": "Login to get JWT token. Change email/password to test with different roles (buyer, seller, shipper).",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"if (jsonData.token) {",
							"    pm.collectionVariables.set('userToken', jsonData.token);",
							"    console.log('Token saved');",
							"}",
							"pm.test('Login successful', function () {",
							"    pm.response.to.have.status(200);",
							"    pm.expect(jsonData.token).to.not.be.empty;",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Content-Type", "value": "application/json" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"buyer@test.com\",\n    \"password\": \"123456\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/auth/login",
					"host": ["{{baseUrl}}"],
					"path": ["api", "auth", "login"]
				}
			}
		},
		{
